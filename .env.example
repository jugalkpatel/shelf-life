# Drizzle
DATABASE_URL=file:./tmp/local.db

# Better Auth
# Leave ORIGIN blank locally so Better Auth can infer the active dev or preview port.
ORIGIN=

# Course-local development secret. Replace this in any shared or production environment.
# Not that we're ever *really* going to production with this application, but just in case…
BETTER_AUTH_SECRET=shelf-local-development-auth-secret-change-me-before-sharing

# Local test helpers and course fixtures
ENABLE_TEST_SEED=true
OPEN_LIBRARY_BASE_URL=https://openlibrary.org
